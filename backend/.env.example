# CONFIGURACION DEL BACKEND que Trabaja con OpenClaw
# El puerto para OpenClaw pude ser 4000 o el deafult 18789 debe coordinarse con Backend

# ── Base de Datos ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SCHEMA=app

# ── Servidor ──────────────────────────────────────
PORT=3000
NODE_ENV=production
TZ=Europe/Madrid

# ── Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# ── OpenClaw ──────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://127.0.0.1:4000
OPENCLAW_GATEWAY_TOKEN=

# Canal de mensajería: whatsapp | telegram
MESSAGING_CHANNEL=telegram

# ── External Tasks API (optel-redes, etc.) ───────
# API key compartida con sistemas externos que crean tareas vía /api/external/tasks.
# Si queda vacío, el endpoint devuelve 503 (deshabilitado).
EXTERNAL_API_KEY=

# ── Archivos ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── OpenAI (Whisper para transcripcion de audio) ─
OPENAI_API_KEY=

# ── Auto Check-in ────────────────────────────────
# Minutos después de inicio de turno para enviar recordatorio
AUTO_CHECKIN_DELAY_MINUTES=15

# ── Auto Check-out ───────────────────────────────
# Minutos después de fin de turno para enviar primer recordatorio
AUTO_CHECKOUT_GRACE_MINUTES=5

# Minutos sin respuesta para cierre automático (se reinicia si dice "aún no")
AUTO_CHECKOUT_CLOSE_MINUTES=20

# ─────────llegadas antes  ─────────
SHIFT_EARLY_TOLERANCE_MINUTES=60

# ──Time Zone default: Europe/Madrid) ─────────
APP_TIMEZONE=Europe/Madrid

#─────────alertas al supervisor ─────────
ALERT_NO_CHECKIN_MINUTES=30    		# default: 60
ALERT_NO_TASK_MINUTES=60       		# default: 60
ALERT_OVERTIME_FACTOR=2        		# default: 2 (doble del tiempo)
ESCALATION_TOKEN_EXPIRY_HOURS=72

# 0=no alertar una vez terminado el turno, >0=dejar N minutos para wrap-up
ALERT_SHIFT_END_GRACE_MINUTES=0

# ── Mobile Checklist ───────────────────────────────
# URL pública (con https:// y sin trailing slash) donde ESTE backend es
# accesible vía nginx. Se usa para construir los links que se envían al
# empleado por Telegram:
#   - /m/assign/:token      (supervisor "agregar tarea")
#   - /m/task/:token        (checklist móvil)
#   - /m/escalation/:token  (formulario de escalación)
# OBLIGATORIO setear. Si queda vacío o como "https://" sin dominio, el
# backend loggea warning al startup y cae al fallback http://localhost:3000
# — los empleados no podrán abrir los links desde Telegram.
# Ejemplos:
#   MOBILE_BASE_URL=https://gestion.talinda.es
#   MOBILE_BASE_URL=https://rrhh.optel.com
MOBILE_BASE_URL=

# Horas de validez del token de acceso (tareas internas / checklist)
TOKEN_EXPIRY_HOURS=24

# Horas de validez del token cuando la tarea pide UI móvil completa
# (requires_mobile_ui=true en app.tasks — típicamente tickets de optel-redes
# u otros sistemas externos NOC/Help-Desk). Default 168 = 7 días, para que
# el técnico tenga margen de retomar el ticket si tarda varios días o si
# se le va el link entre conversaciones.
TOKEN_EXPIRY_HOURS_EXTERNAL=168

# ── CHECKIN/CHECKOUT con LOCALIZACION ───────────────────────────────
LOCATION_CHECK_ENABLED=false
LOCATION_DEFAULT_LAT=
LOCATION_DEFAULT_LNG=
LOCATION_DEFAULT_RADIUS_M=150
