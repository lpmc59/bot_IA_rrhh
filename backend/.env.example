# ── Base de Datos ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talindadb
DB_USER=talindadb_app
DB_PASSWORD=TalindA2020
DB_SCHEMA=app

# ── Base de Datos Talinda (fuente proveedores) ────
TALINDA_DB_URL=postgresql://talindadb_app:TalindA2020@localhost:5432/talinda

# ── Servidor ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Anthropic (Claude Sonnet 4) ───────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenClaw ──────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:4000
OPENCLAW_GATEWAY_TOKEN=tu-token-aqui

# ── Archivos ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Auto Check-in ────────────────────────────────
# Minutos después de inicio de turno para enviar recordatorio
AUTO_CHECKIN_DELAY_MINUTES=5

# ── Auto Check-out ───────────────────────────────
# Minutos después de fin de turno para enviar primer recordatorio
AUTO_CHECKOUT_GRACE_MINUTES=5
# Minutos sin respuesta para cierre automático (se reinicia si dice "aún no")
AUTO_CHECKOUT_CLOSE_MINUTES=20
